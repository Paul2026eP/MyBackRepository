CREATE SCHEMA empresa;
USE empresa;

SELECT * FROM tb_object_funcionario;
SELECT JSON_EXTRACT (JSON, "$.Primeiro_Nome", "$.Data_Nascimento", "$.Numero_Departamento") FROM tb_object_funcionario;
SELECT JSON_UNQUOTE (JSON_EXTRACT (JSON, "$.Primeiro_Nome")),
JSON_EXTRACT (JSON,  "$.Data_Nascimento"),
JSON_EXTRACT (JSON, "$.Salario") FROM tb_object_funcionario;

SELECT
JSON_TYPE(JSON_EXTRACT(JSON, "$.Data_Nascimento")),
JSON_TYPE(JSON_EXTRACT(JSON, "$.Salario")),
JSON_TYPE(JSON_EXTRACT(JSON, "$.Primeiro_Nome")) FROM tb_object_funcionario
WHERE YEAR (JSON_EXTRACT(JSON, "$.Data_Nascimento")) >=1980;

SELECT JSON_EXTRACT (JSON, "$.Dependentes") FROM tb_object_funcionario;
SELECT JSON_EXTRACT (JSON, "$.Dependentes[0].Parentesco") FROM tb_object_funcionario;
SELECT JSON_EXTRACT (JSON, "$.Dependentes[1].Sexo") FROM tb_object_funcionario; -- [n°] indica o bloco da busca


SELECT JSON_EXTRACT (JSON, "$.Dependentes[0].Parentesco") FROM tb_object_funcionario UNION SELECT JSON_EXTRACT (JSON, "$.Dependentes[1].Parentesco") FROM tb_object_funcionario;
SELECT JSON_EXTRACT (JSON, "$.Dependentes[0].Parentesco") AS Parentescos FROM tb_object_funcionario UNION SELECT JSON_EXTRACT (JSON, "$.Dependentes[1].Parentesco")  FROM tb_object_funcionario;

SELECT T1.PARENTESCO, T1.SEXO FROM tb_object_funcionario 
CROSS JOIN
JSON_TABLE(
JSON_EXTRACT(JSON, "$.Dependentes"), "$[*]" 
COLUMNS(PARENTESCO VARCHAR(20) PATH "$.Parentesco", 
SEXO VARCHAR(2) PATH "$.Sexo")) as T1;

/*Crie uma tabela baseada no campo dependentes com uma coluna Sexo, Parantesco, Data de Nascimento e Nome de Dependente (tb_object_funcionario). Além disso, utilize o INNER JOIN
para adicionar o nome do departamento (tb_departamento).*/

SELECT 
   T1.Sexo,
   T1.Parentesco,
   T1.DataNascimento,
   T1.NomeDependente,
FROM tb_object_funcionario,  
SELECT D.NOME_DEPARTAMENTO 
FROM tb_departamento
INNER JOIN tb_departamento D 
    JSON_EXTRACT(F.JSON, "$.Dependentes"), "$[*]"
    COLUMNS(
        NomeDependente VARCHAR(100) PATH "$.Nome",
        DataNascimento DATE PATH "$.DataNascimento",
        Sexo VARCHAR(2) PATH "$.Sexo",
        Parentesco VARCHAR(20) PATH "$.Parentesco", 
    )
) AS T1;


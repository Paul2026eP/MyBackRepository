-- ATIVIDADE 3 - CONSULTAS MYSQL COM JSON 

 -- Baseando-se no banco de dados world_x, realize as seguintes consultas:

-- Consulta 1: Escreva uma consulta que retorne o nome do país e a expectativa de vida de todos os países que pertencem à América do Sul.
SELECT 
    JSON_EXTRACT(doc, "$.Name") AS nome_pais,
    JSON_EXTRACT(doc, "$.demographics.LifeExpectancy") AS expectativa_vida
FROM 
    countryinfo
WHERE 
    JSON_EXTRACT(doc, "$.geography.Region") = 'South America';
    
    SELECT * FROM countryinfo;

-- Consulta 2: Escreva uma consulta que liste todos os países onde o Produto Nacional Bruto (GNP) é maior que 500.000 e que possuam o idioma Inglês como um de seus idiomas oficiais.
SELECT  -- Corrigir
    JSON_EXTRACT(doc, "$.Name") AS nome_pais,
    JSON_EXTRACT(doc, "$.economy.GNP") AS produto_nacional_bruto,
    JSON_EXTRACT(doc, "$.languages") AS idiomas
FROM 
    countryinfo
WHERE 
    CAST(JSON_EXTRACT(doc, "$.economy.GNP") AS DECIMAL) > 500000
    AND JSON_EXTRACT(doc, "$.languages") LIKE '%English%';


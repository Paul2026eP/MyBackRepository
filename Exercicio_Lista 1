# Exercício 2

/*Analise as consultas SQL abaixo e aponte os erros de sintaxe. Tanto 
as estruturas JSON quanto os comandos SQL podem estar erradas.*/

/* a) O JSON_EXTRACT precisa receber primeiro a coluna que contém o JSON e depois os caminhos ($.campo) que você quer extrair, e o WHERE deve ter 
uma condição, não apenas o nome da tabela. */
SELECT 
	JSON_EXTRACT('$.Primeiro_Nome', 
    '$.Data_Nascimento', '$.Salario') 
WHERE tb_object_funcionario; 

-- b)
SELECT 
	JSON_UNQUOTE(JSON_EXTRACT(JSON,"$.Primeiro_Nome")), #...Falta a virgula o JSON_UNQUOTE não aceita os dois argumentos 
    JSON_UNQUOTE(JSON_EXTRACT(JSON,"$.Data_Nascimento"), #...Falta um Parenteses
    JSON_EXTRACT(JSON,"$.Salario")
FROM empresa; # Tabela empresa não existe

-- c) Uso incorreto de alias na lista (T1.PARENTESCO), e Sintaxe do JSON_TABLE.
SELECT T1.PARENTESCO, T1.SEXO FROM tb_object_funcionario
CROSS JOIN
JSON_TABLE (
	JSON_EXTRACT(JSON, "$.Dependentes") "$[*]" #...Falta uma virgula após o parenteses.
    COLUMNS (PARENTESCO VARCHAR(50) "$.Parentesco", #...Falta PATH no uso da sintese
			SEXO VARCHAR(50) PATH "$.Sexo")
) AS T2;

-- d)
SELECT JSON_KEYS(doc, "geography") FROM countryinfo #...Correto usar $. antes do geography para sintese
WHERE _id = 'BRA'; #... id no banco de dados analisado (world_x) é em formato de numero 00000..., BRA é um CODE

SELECT * FROM countryinfo;

-- e)
SELECT JSON_EXTRACT(doc, "$.GNP") as GNP
  , JSON_EXTRACT(doc, "$.Code") as Code
  , JSON_EXTRACT(doc, "$.Name") as Name
  , JSON_EXTRACT(doc, "$.IndepYear") as IndepYear
  , JSON_EXTRACT(doc, "$.geography.Region") as Region
  , JSON_EXTRACT(doc, "$.geography.Continent") as Continent
  , JSON_EXTRACT(doc, "$.geography[0]") as SurfaceArea #Erro de sentido, só é usado [0] em lista; uso incorreto de índices em objetos JSON.
  , JSON_EXTRACT(doc, "$.government.HeadOfState") as HeadOfState
  , JSON_EXTRACT(doc, "$.government.GovernmentForm") as GovernmentForm
  , JSON_EXTRACT(doc, "$.demographics") as Population #...Falta uma virgula após population para separa JSON, e Inconsistência na extração de campos o correto $.demographics.population
    JSON_EXTRACT(doc, "$.demographics.LifeExpectancy") as LifeExpectancy
  FROM countryinfo;
  
-- f)
SELECT JSON_EXTRACT("$.geography.Continent") as Continent, #Falta o doc pra extrair do JSON.
(JSON_EXTRACT(doc, "$.demographics.Population")) as Population,
AVG(JSON_EXTRACT(doc, "$.demographics.LifeExpectancy")) as LifeExpectancy 
WHERE JSON_EXTRACT(doc, "$.government.") LIKE('%Monarchy%'), #... Ponto . sobrando, e virgula invalida, o correto sem parenteses e  sem virgula para ligar o FROM
FROM countryinfo
GROUP BY JSON_EXTRACT(doc, "$.geography")
ORDER BY 2; #...Pouco claro, o correto usar Population
